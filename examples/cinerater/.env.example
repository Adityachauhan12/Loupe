# Copy to .env and fill in. The agent loads these via python-dotenv.

# From `python -m scripts.create_project cinerater` (run in server/)
LOUPE_API_KEY=lp_replace_me

# Where the Loupe server is listening. Local dev default:
LOUPE_HOST=http://localhost:8000

# Get one at https://console.groq.com — free tier is fine for the demo.
GROQ_API_KEY=gsk_replace_me

# Optional — override the Groq model used by the agent.
GROQ_MODEL=llama-3.3-70b-versatile
