# Copy to .env and fill in.

# From `python -m scripts.create_project github-triage` (run in server/)
LOUPE_API_KEY=lp_replace_me

# Where the Loupe server is listening. Local dev default:
LOUPE_HOST=http://localhost:8000

# Get one at https://console.groq.com — free tier is fine.
GROQ_API_KEY=gsk_replace_me

# Get one at https://github.com/settings/tokens — needs repo scope (read issues + write labels/comments)
GITHUB_TOKEN=ghp_replace_me

# Which repo to triage — format: owner/repo
GITHUB_REPO=Adityachauhan12/loupe

# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile
MAX_ISSUES=10
